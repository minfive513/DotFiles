{
  "layer": "bottom",
  "position": "top",
  "height": 24,
  "spacing": 5,
  "modules-left": ["sway/workspaces","sway/mode","sway/window"],
  "modules-center": [],
  "modules-right": ["cpu","memory","battery","battery1","backlight","pulseaudio", "idle_inhibitor","clock","tray"],
  "sway/mode": {
    "format": "{}"
  },
  "sway/window": {
    "format": "{title}"
  },
  "cpu": { 
    "interval": 10, 
    "format": "\uf2db {usage}%" 
  },
  "memory": {
    "interval": 30,
    "format": "\uf233 {used:0.1f}GiB/{total:0.1f}GiB"
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 5
    },
    "format": "{icon} BAT0: {capacity}%",
    "format-charging": "BAT0: {capacity}% (charging)",
    "format-plugged": "BAT0: {capacity}% (plugged)",
    "format-icons": ["\uf244", "\uf243", "\uf242", "\uf241", "\uf240"]
  },
  "battery1": {
    "bat": "BAT1",
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 5
    },
    "format": "{icon} BAT1: {capacity}%",
    "format-charging": "BAT1: {capacity}% (charging)",
    "format-plugged": "BAT1: {capacity}% (plugged)",
    "format-icons": ["\uf244", "\uf243", "\uf242", "\uf241", "\uf240"]
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "device": "intel_backlight",
    
    "format-icons": {
      "default": ["\uf185"]
    }
  },
  "clock": {
    "format": "{:%d.%m.%Y %H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>"
      }
    }
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-icons": {
      "default": ["\uf026", "\uf027", "\uf028"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "format-muted": "\uf00d {volume}%"
  },
  "idle_inhibitor": {
	"format": "{icon}",
	"format-icons": {
		"activated": "",
		"deactivated": ""
	},
	"timeout": 30.5
  },
  "tray": {
    "icon-size": 20,
    "spacing": 10
  }
}